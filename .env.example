# Copy this file to .env and fill in real values before running.
# .env is git-ignored — never commit real secrets.

DEVICE_NAME=Windows-Laptop

# --- Collection tuning ---
COLLECT_INTERVAL_SECONDS=5
BROADCAST_INTERVAL_SECONDS=2

# --- Database ---
DB_PATH=data/metrics.db

# --- Alerting cooldown (seconds) ---
ALERT_COOLDOWN_SECONDS=300

# --- Telegram alerts ---
# 1. Message @BotFather on Telegram -> /newbot -> copy the token below
# 2. Message your new bot once, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8579057686:AAHl85s-EvyTavSp_c-nttbpmJLgBE6X2Bs
TELEGRAM_CHAT_ID=1141481554

# --- Email alerts (SMTP) ---
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tthariq898@gmail.com
SMTP_PASSWORD=boelmbplvznugyyu
ALERT_EMAIL_TO=thariqthajudeen707@gmail.com

# --- MQTT (bonus: IoT protocol support) ---
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=seaker/metrics

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
